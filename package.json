{
  "name": "letter-generator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/apply-user-error-flyout-wiring.mjs && node scripts/apply-manager-template-storage-wiring.mjs && node scripts/apply-manager-template-ui-wiring.mjs && node scripts/apply-manager-template-workspace-state-wiring.mjs && node scripts/apply-manager-workspace-nav-wiring.mjs && node scripts/apply-manager-template-generation-wiring.mjs",
    "dev": "next dev",
    "codespace:dev": "next dev --hostname 0.0.0.0 --port 3000",
    "pretypecheck": "node scripts/apply-manager-template-workspace-state-wiring.mjs && node scripts/apply-manager-template-generation-wiring.mjs && node scripts/phase14-local-safety-check.mjs",
    "typecheck": "tsc --noEmit",
    "prebuild": "node scripts/apply-manager-template-workspace-state-wiring.mjs && node scripts/apply-manager-template-generation-wiring.mjs && node scripts/phase14-local-safety-check.mjs",
    "build": "next build",
    "start": "next start",
    "console-shell:guard": "node scripts/console-shell-contract-guard.mjs",
    "quality:check": "npm run console-shell:guard && npm run manager-template:guard && npm run manager-template:db-guard && npm run typecheck && npm run build",
    "repo:guard": "npm run console-shell:guard && node scripts/manager-visible-switch-contract-guard.mjs && npm run manager-template:guard && npm run manager-template:db-guard && npm run typecheck && npm run build",
    "codespace:verify": "npm run repo:guard",
    "manager-template:guard": "node scripts/manager-template-roadmap-guard.mjs",
    "manager-template:db-guard": "node scripts/manager-template-database-guard.mjs",
    "ai:code": "node scripts/ai-coding-assistant.js",
    "ai:code:interactive": "node scripts/ai-coding-assistant.js --interactive",
    "ai:code:help": "node scripts/ai-coding-assistant.js --help",
    "ai:process": "node scripts/ai-code-processor.js",
    "ai:apply": "node scripts/apply-changes.js",
    "xdisputer:guard": "npm run repo:guard",
    "dynamic-template:v2:regression": "node scripts/dynamic-template-v2-regression.mjs",
    "safe:sync": "bash scripts/safe-sync-guard.sh",
    "init:connections": "npm run connections:doctor",
    "connections:doctor": "node scripts/check-env-contract.mjs",
    "supabase:doctor": "node scripts/check-env-contract.mjs",
    "active:sync": "npm run codespace:verify",
    "active:sync:db": "npm run supabase:doctor && npm run codespace:verify"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "docx-preview": "^0.3.6",
    "docxtemplater": "^3.68.7",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "next": "^16.2.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.296",
    "pizzip": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
