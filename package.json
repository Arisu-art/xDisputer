{
  "name": "letter-generator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/apply-user-error-flyout-wiring.mjs && node scripts/apply-manager-template-storage-wiring.mjs && node scripts/apply-manager-template-ui-wiring.mjs && node scripts/apply-manager-workspace-nav-wiring.mjs && node scripts/apply-manager-template-generation-wiring.mjs",
    "dev": "next dev",
    "pretypecheck": "node scripts/apply-manager-template-generation-wiring.mjs && node scripts/phase14-local-safety-check.mjs",
    "typecheck": "tsc --noEmit",
    "prebuild": "node scripts/apply-manager-template-generation-wiring.mjs && node scripts/phase14-local-safety-check.mjs",
    "build": "next build",
    "start": "next start",
    "quality:check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "docx-preview": "^0.3.6",
    "docxtemplater": "^3.68.7",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "next": "^16.2.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.296",
    "pizzip": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
