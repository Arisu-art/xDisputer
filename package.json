{
  "name": "letter-generator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/repair-letter-workspace-syntax.mjs",
    "build": "next build",
    "start": "next start",
    "ai:code": "node scripts/ai-coding-assistant.js",
    "ai:code:interactive": "node scripts/ai-coding-assistant.js --interactive",
    "ai:code:help": "node scripts/ai-coding-assistant.js --help",
    "ai:process": "node scripts/ai-code-processor.js",
    "ai:apply": "node scripts/apply-changes.js",
    "pretypecheck": "node scripts/repair-letter-workspace-syntax.mjs",
    "typecheck": "tsc --noEmit",
    "quality:check": "npm run typecheck && npm run build",
    "xdisputer:guard": "node scripts/xdisputer-deploy-guard.mjs",
    "safe:sync": "bash scripts/safe-sync-guard.sh",
    "verify:production": "node scripts/verify-production-build.mjs",
    "verify:production:wait": "node scripts/wait-for-production-build.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "docx-preview": "^0.3.6",
    "docxtemplater": "^3.68.7",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "next": "^16.2.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.296",
    "pizzip": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
